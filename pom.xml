        <jackson.version>2.14.0</jackson.version>
        <spring-framework.version>6.0.0</spring-framework.version>
        <hikaricp.version>5.0.1</hikaricp.version>
        <freemarker.version>2.3.31</freemarker.version>
        <bouncycastle.version>1.72</bouncycastle.version>
        <jasypt.version>1.9.3</jasypt.version>
        <thumbnailator.version>0.4.18</thumbnailator.version>
        <guava.version>31.1-jre</guava.version>
        <netty5.version>5.0.0.Alpha5</netty5.version>
        <zxing.version>3.5.1</zxing.version>
        <poi.version>5.2.3</poi.version>
        <mysql-connector-j.version>8.0.30</mysql-connector-j.version>
        <jna.version>5.12.1</jna.version>
        <slf4j.version>2.0.4</slf4j.version>
        <log4j2.version>2.19.0</log4j2.version>

        <!-- ********************* 以下为测试依赖包版本 ********************** -->
        <testng.version>7.6.1</testng.version>

        <!-- ************************ 以下为插件版本 ************************ -->
        <maven.resources.plugin.version>3.3.0</maven.resources.plugin.version>
        <maven.compiler.plugin.version>3.10.1</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.0.0-M7</maven.surefire.plugin.version>
        <maven.jar.plugin.version>3.3.0</maven.jar.plugin.version>
        <maven.source.plugin.version>3.2.1</maven.source.plugin.version>
        <maven.javadoc.plugin.version>3.4.1</maven.javadoc.plugin.version>
        <maven.gpg.plugin.version>3.0.1</maven.gpg.plugin.version>
        <maven.install.plugin.version>3.0.1</maven.install.plugin.version>
        <maven.deploy.plugin.version>3.0.0</maven.deploy.plugin.version>
